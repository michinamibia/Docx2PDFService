{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LibreOffice": {
    // Override the LibreOffice executable path if it is not on PATH.
    // Windows example: "C:\\Program Files\\LibreOffice\\program\\soffice.exe"
    // Linux  example: "/usr/bin/libreoffice"
    // Leave empty to use auto-detection.
    "ExecutablePath": ""
  },
  "AzureBlob": {
    // When set, converted PDFs are uploaded to Azure Blob Storage and
    // the response will be a JSON object { "url": "..." } instead of the PDF bytes.
    // Leave ConnectionString empty to return PDF bytes directly (default).
    "ConnectionString": "",
    "ContainerName": "pdfs",
    // How long (in hours) the SAS download URL is valid. Default: 24.
    "SasExpiryHours": 24
  }
}
